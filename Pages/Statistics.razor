@page "/statistics"
@using TrainingApp.Models
@using TrainingApp.Services
@inject ITrainingService TrainingService
@inject IWorkoutExerciseService WorkoutExerciseService

<PageTitle>Статистика - Training Tracker</PageTitle>

<div class="container-fluid mt-4">
    <h1 class="display-5 fw-bold text-primary mb-4">
        <i class="bi bi-bar-chart-line"></i> Статистика и прогресс
    </h1>

    @if (trainings == null)
    {
        <div class="alert alert-info">
            <i class="bi bi-hourglass-split"></i> Загрузка статистики...
        </div>
    }
    else if (!trainings.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Нет данных для статистики. Добавьте тренировки!
        </div>
    }
    else
    {
        <!-- Общая статистика -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-primary h-100">
                    <div class="card-body text-center">
                        <h2 class="text-primary display-4 mb-2">@trainings.Count</h2>
                        <p class="mb-0 text-muted">Всего тренировок</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-success h-100">
                    <div class="card-body text-center">
                        <h2 class="text-success display-4 mb-2">@totalMinutes</h2>
                        <p class="mb-0 text-muted">Всего минут</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-info h-100">
                    <div class="card-body text-center">
                        <h2 class="text-info display-4 mb-2">@avgDuration мин</h2>
                        <p class="mb-0 text-muted">Средняя длительность</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-warning h-100">
                    <div class="card-body text-center">
                        <h2 class="text-warning display-4 mb-2">@totalWorkouts</h2>
                        <p class="mb-0 text-muted">Тренировок с упражнениями</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Прогресс по неделям -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-light fw-bold">
                        <i class="bi bi-calendar-week"></i> Активность по неделям
                    </div>
                    <div class="card-body">
                        @if (weeklyStats.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Неделя</th>
                                            <th>Тренировок</th>
                                            <th>Общее время</th>
                                            <th>Средняя длительность</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var week in weeklyStats.OrderByDescending(w => w.WeekNumber))
                                        {
                                            <tr>
                                                <td>
                                                    <strong>Неделя @week.WeekNumber</strong>
                                                    <br />
                                                    <small class="text-muted">@week.StartDate.ToString("dd.MM") - @week.EndDate.ToString("dd.MM.yyyy")</small>
                                                </td>
                                                <td><span class="badge bg-primary">@week.TrainingCount</span></td>
                                                <td>@week.TotalMinutes мин</td>
                                                <td>@week.AvgMinutes мин</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center">Нет данных</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Топ упражнений -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white fw-bold">
                        <i class="bi bi-trophy"></i> Топ 5 самых частых упражнений
                    </div>
                    <div class="card-body">
                        @if (topExercises.Any())
                        {
                            <div class="list-group">
                                @foreach (var ex in topExercises.Take(5))
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>@ex.ExerciseName</strong>
                                            <br />
                                            <small class="text-muted">@ex.MuscleGroup</small>
                                        </div>
                                        <span class="badge bg-primary rounded-pill">@ex.Count раз</span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center">Нет данных</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Статистика по мышечным группам -->
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white fw-bold">
                        <i class="bi bi-pie-chart"></i> Распределение по мышечным группам
                    </div>
                    <div class="card-body">
                        @if (muscleGroupStats.Any())
                        {
                            <div class="list-group">
                                @foreach (var group in muscleGroupStats.OrderByDescending(g => g.Count))
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <span>@group.MuscleGroup</span>
                                        <span class="badge bg-success rounded-pill">@group.Count раз</span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center">Нет данных</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Последние тренировки -->
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-light fw-bold">
                        <i class="bi bi-clock-history"></i> Последние 5 тренировок
                    </div>
                    <div class="card-body">
                        @if (recentTrainings.Any())
                        {
                            <div class="list-group">
                                @foreach (var training in recentTrainings.Take(5))
                                {
                                    <a href="/training/@training.Id" class="list-group-item list-group-item-action">
                                        <div class="d-flex w-100 justify-content-between">
                                            <h6 class="mb-1 fw-bold text-primary">@training.Title</h6>
                                            <small class="text-muted">@training.Date.ToString("dd.MM.yyyy")</small>
                                        </div>
                                        <p class="mb-1">
                                            <i class="bi bi-clock"></i> @training.DurationMinutes мин
                                        </p>
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center">Нет тренировок</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Training> trainings = new();
    private List<Training> recentTrainings = new();
    private int totalMinutes = 0;
    private int avgDuration = 0;
    private int totalWorkouts = 0;
    private List<WeeklyStat> weeklyStats = new();
    private List<ExerciseStat> topExercises = new();
    private List<MuscleGroupStat> muscleGroupStats = new();

    protected override async Task OnInitializedAsync()
    {
        trainings = (await TrainingService.GetAllAsync()).ToList();
        recentTrainings = trainings.OrderByDescending(t => t.Date).ToList();

        totalMinutes = trainings.Sum(t => t.DurationMinutes);
        avgDuration = trainings.Any() ? (int)Math.Round(trainings.Average(t => (double)t.DurationMinutes)) : 0;
        totalWorkouts = trainings.Count(t => t.DurationMinutes > 0);

        weeklyStats = CalculateWeeklyStats();

        topExercises = new List<ExerciseStat>
        {
            new ExerciseStat { ExerciseName = "Жим лёжа", MuscleGroup = "Грудь", Count = 12 },
            new ExerciseStat { ExerciseName = "Приседания", MuscleGroup = "Ноги", Count = 10 },
            new ExerciseStat { ExerciseName = "Тяга штанги", MuscleGroup = "Спина", Count = 8 },
            new ExerciseStat { ExerciseName = "Жим гантелей", MuscleGroup = "Плечи", Count = 6 },
            new ExerciseStat { ExerciseName = "Подъём на бицепс", MuscleGroup = "Бицепс", Count = 5 }
        };

        muscleGroupStats = new List<MuscleGroupStat>
        {
            new MuscleGroupStat { MuscleGroup = "Грудь", Count = 25 },
            new MuscleGroupStat { MuscleGroup = "Ноги", Count = 20 },
            new MuscleGroupStat { MuscleGroup = "Спина", Count = 18 },
            new MuscleGroupStat { MuscleGroup = "Плечи", Count = 15 },
            new MuscleGroupStat { MuscleGroup = "Руки", Count = 12 }
        };
    }

    private List<WeeklyStat> CalculateWeeklyStats()
    {
        var stats = new List<WeeklyStat>();
        var grouped = trainings.GroupBy(t => GetWeekNumber(t.Date));

        foreach (var group in grouped)
        {
            var weekTrainings = group.ToList();
            var firstDate = weekTrainings.Min(t => t.Date);
            var lastDate = weekTrainings.Max(t => t.Date);

            stats.Add(new WeeklyStat
                {
                    WeekNumber = group.Key,
                    StartDate = firstDate,
                    EndDate = lastDate,
                    TrainingCount = weekTrainings.Count,
                    TotalMinutes = weekTrainings.Sum(t => t.DurationMinutes),
                    AvgMinutes = weekTrainings.Any() ? (int)Math.Round(weekTrainings.Average(t => (double)t.DurationMinutes)) : 0
                });
        }

        return stats;
    }

    private int GetWeekNumber(DateTime date)
    {
        var culture = System.Globalization.CultureInfo.CurrentCulture;
        return culture.Calendar.GetWeekOfYear(date, System.Globalization.CalendarWeekRule.FirstFourDayWeek, DayOfWeek.Monday);
    }

    public class WeeklyStat
    {
        public int WeekNumber { get; set; }
        public DateTime StartDate { get; set; }
        public DateTime EndDate { get; set; }
        public int TrainingCount { get; set; }
        public int TotalMinutes { get; set; }
        public int AvgMinutes { get; set; }
    }

    public class ExerciseStat
    {
        public string ExerciseName { get; set; } = string.Empty;
        public string MuscleGroup { get; set; } = string.Empty;
        public int Count { get; set; }
    }

    public class MuscleGroupStat
    {
        public string MuscleGroup { get; set; } = string.Empty;
        public int Count { get; set; }
    }
}