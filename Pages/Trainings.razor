@page "/trainings"
@using TrainingApp.Models
@using TrainingApp.Services
@inject ITrainingService TrainingService
@inject NavigationManager Navigation

<PageTitle>Тренировки - Training Tracker</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold text-primary">
            <i class="bi bi-calendar-plus"></i> Тренировки
        </h1>
        <div>
            <button class="btn btn-outline-primary me-2" @onclick="ToggleView">
                <i class="bi bi-@(viewMode == "table" ? "grid-3x3" : "list-ul")"></i>
                @(viewMode == "table" ? "Карточки" : "Таблица")
            </button>
            <button class="btn btn-primary btn-lg" @onclick="ShowAddForm">
                <i class="bi bi-plus-circle"></i> Добавить тренировку
            </button>
        </div>
    </div>

    @if (showForm)
    {
        <div class="card shadow-lg mb-4 border-primary">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">
                    @(isEditing ? "✏️ Редактирование тренировки" : "➕ Новая тренировка")
                </h4>
            </div>
            <div class="card-body">
                @if (errorMessage != "")
                {
                    <div class="alert alert-danger mb-3">
                        <strong>⚠️ Ошибка:</strong> @errorMessage
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label fw-bold">Название тренировки *</label>
                        <input @bind="currentTraining.Title" class="form-control form-control-lg"
                               placeholder="Например: Понедельник - Тяжёлый жим" />
                        @if (titleError != "")
                        {
                            <div class="text-danger mt-1"><strong>@titleError</strong></div>
                        }
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Дата *</label>
                        <input type="date" @bind="currentTraining.Date" class="form-control form-control-lg" />
                        @if (dateError != "")
                        {
                            <div class="text-danger mt-1"><strong>@dateError</strong></div>
                        }
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Длительность (минут) *</label>
                        <input type="number" @bind="currentTraining.DurationMinutes" class="form-control form-control-lg" />
                        @if (durationError != "")
                        {
                            <div class="text-danger mt-1"><strong>@durationError</strong></div>
                        }
                    </div>

                    <div class="col-md-8">
                        <label class="form-label fw-bold">Описание программы</label>
                        <textarea @bind="currentTraining.Description" class="form-control" rows="5"
                                  placeholder="Описание тренировки, упражнения, подходы, повторения..."></textarea>
                    </div>

                    <div class="col-12 mt-4">
                        <button class="btn btn-success btn-lg me-2" @onclick="SaveTraining">
                            <i class="bi bi-check-circle"></i> Сохранить
                        </button>
                        <button class="btn btn-secondary btn-lg" @onclick="CancelForm">
                            <i class="bi bi-x-circle"></i> Отмена
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (trainings == null)
    {
        <div class="alert alert-info">
            <i class="bi bi-hourglass-split"></i> Загрузка тренировок...
        </div>
    }
    else if (!trainings.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Тренировок пока нет. Добавьте первую!
        </div>
    }
    else
    {
        @if (viewMode == "table")
        {
            <!-- ТАБЛИЦА -->
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-list-ul"></i> Список тренировок (@trainings.Count)</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-primary">
                            <tr>
                                <th style="width: 5%">#</th>
                                <th style="width: 30%">Название</th>
                                <th style="width: 15%">Дата</th>
                                <th style="width: 10%">Длительность</th>
                                <th style="width: 30%">Описание</th>
                                <th style="width: 10%">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var training in trainings.OrderBy(t => t.Date))
                            {
                                <tr>
                                    <td><span class="badge bg-primary">@training.Id</span></td>
                                    <td><strong>@training.Title</strong></td>
                                    <td>@training.Date.ToString("dd.MM.yyyy")</td>
                                    <td><span class="badge bg-success">@training.DurationMinutes мин</span></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(training.Description))
                                        {
                                            @(training.Description.Length > 50
                                                ? training.Description.Substring(0, 50) + "..."
                                                : training.Description)
                                        }
                                        else
                                        {
                                            <span class="text-muted">Нет описания</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditTraining(training)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <a href="/training/@training.Id" class="btn btn-sm btn-outline-info me-1">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTraining(training.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <!-- КАРТОЧКИ -->
            <div class="row">
                @foreach (var training in trainings.OrderBy(t => t.Date))
                {
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100 shadow-sm border-0 hover-card">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0">@training.Title</h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <span class="badge bg-primary me-2">
                                        <i class="bi bi-calendar3"></i> @training.Date.ToString("dd.MM.yyyy")
                                    </span>
                                    <span class="badge bg-success">
                                        <i class="bi bi-clock"></i> @training.DurationMinutes мин
                                    </span>
                                </div>
                                @if (!string.IsNullOrEmpty(training.Description))
                                {
                                    <p class="card-text text-muted" style="white-space: pre-line;">
                                        @training.Description
                                    </p>
                                }
                                else
                                {
                                    <p class="card-text text-muted fst-italic">Нет описания</p>
                                }
                            </div>
                            <div class="card-footer bg-white border-top">
                                <div class="btn-group w-100" role="group">
                                    <button class="btn btn-sm btn-primary" @onclick="() => EditTraining(training)">
                                        <i class="bi bi-pencil"></i> Изменить
                                    </button>
                                    <a href="/training/@training.Id" class="btn btn-sm btn-info text-white">
                                        <i class="bi bi-eye"></i> Просмотр
                                    </a>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteTraining(training.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<style>
    .hover-card {
        transition: all 0.3s ease;
    }

        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
        }
</style>

@code {
    private List<Training> trainings = new();
    private Training currentTraining = new();
    private bool showForm = false;
    private bool isEditing = false;
    private string viewMode = "table"; // "table" или "cards"

    // Ошибки валидации
    private string errorMessage = "";
    private string titleError = "";
    private string dateError = "";
    private string durationError = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadTrainings();
    }

    private async Task LoadTrainings()
    {
        var result = await TrainingService.GetAllAsync();
        trainings = result.ToList();
    }

    private void ToggleView()
    {
        viewMode = viewMode == "table" ? "cards" : "table";
    }

    private void ShowAddForm()
    {
        currentTraining = new Training
            {
                Date = DateTime.Today,
                DurationMinutes = 60
            };
        isEditing = false;
        showForm = true;
        ClearErrors();
    }

    private void EditTraining(Training training)
    {
        currentTraining = new Training
            {
                Id = training.Id,
                Title = training.Title,
                Date = training.Date,
                DurationMinutes = training.DurationMinutes,
                Description = training.Description
            };
        isEditing = true;
        showForm = true;
        ClearErrors();
    }

    private async Task SaveTraining()
    {
        ClearErrors();
        bool hasError = false;

        if (string.IsNullOrWhiteSpace(currentTraining.Title))
        {
            titleError = "Название обязательно!";
            hasError = true;
        }
        else if (currentTraining.Title.Length > 100)
        {
            titleError = "Максимум 100 символов!";
            hasError = true;
        }

        if (currentTraining.Date == default || currentTraining.Date.Year < 2020)
        {
            dateError = "Выберите корректную дату!";
            hasError = true;
        }

        if (currentTraining.DurationMinutes <= 0)
        {
            durationError = "Длительность должна быть больше 0!";
            hasError = true;
        }
        else if (currentTraining.DurationMinutes > 1440)
        {
            durationError = "Максимум 24 часа (1440 минут)!";
            hasError = true;
        }

        if (hasError)
        {
            errorMessage = "Исправьте ошибки в форме!";
            return;
        }

        try
        {
            if (isEditing)
            {
                await TrainingService.UpdateAsync(currentTraining);
            }
            else
            {
                await TrainingService.AddAsync(currentTraining);
            }

            currentTraining = new Training();
            showForm = false;
            isEditing = false;
            ClearErrors();
            await LoadTrainings();
        }
        catch (Exception ex)
        {
            errorMessage = "Ошибка: " + ex.Message;
        }
    }

    private void CancelForm()
    {
        currentTraining = new Training();
        showForm = false;
        isEditing = false;
        ClearErrors();
    }

    private async Task DeleteTraining(int id)
    {
        await TrainingService.DeleteAsync(id);
        await LoadTrainings();
    }

    private void ClearErrors()
    {
        errorMessage = "";
        titleError = "";
        dateError = "";
        durationError = "";
    }
}