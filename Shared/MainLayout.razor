@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://github.com" target="_blank">GitHub</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<style>
    .page {
        position: relative;
        display: flex;
        flex-direction: row;
        height: 100vh;
    }

    .sidebar {
        background: linear-gradient(180deg, #2d3748 0%, #1a202c 100%);
        min-height: 100vh;
        width: 250px;
        flex-shrink: 0;
    }

    main {
        flex: 1;
        overflow-y: auto;
        background: white;
    }

    .top-row {
        background-color: #f7f7f7;
        border-bottom: 1px solid #d6d5d5;
        padding: 10px 20px;
    }

    .content {
        padding: 20px;
        min-height: calc(100vh - 50px);
    }
</style>